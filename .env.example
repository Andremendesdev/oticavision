# ============================================================
# Supabase — Dashboard → Settings → API Keys
# ============================================================

# URL do projeto (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# RECOMENDADO: Legacy anon key (aba "Legacy API Keys", começa com eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alternativa: publishable key (aba "API Keys", sb_publishable_...)
# Só use se estiver ativa no projeto — se der "Invalid API key", use a anon acima.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ============================================================
# Admin único
# ============================================================

# Mesmo e-mail do usuário criado em Authentication → Users
ADMIN_EMAIL=

# Opcional — só para: pnpm create-admin
# ADMIN_PASSWORD=
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Sanity — sanity.io/manage → Project ID
# ============================================================

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-30

# ============================================================
# Site / contato
# ============================================================

NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_GOOGLE_REVIEW_URL=
NEXT_PUBLIC_MAP_LAT=
NEXT_PUBLIC_MAP_LNG=
NEXT_PUBLIC_ADDRESS=
NEXT_PUBLIC_LOCATION_LABEL=
